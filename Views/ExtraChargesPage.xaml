<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GlassBilling.Views.ExtraChargesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:GlassBilling.ViewModels"
    Title="Extra Charges"
    BackgroundColor="{StaticResource BackgroundColor}">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="16,14" Spacing="14">

                <!-- Page title matching screenshot style -->
                <Label Text="Enter Extra Charges"
                       FontSize="20" FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}"
                       HorizontalOptions="Center"
                       Margin="0,0,0,4" />

                <!-- ── Predefined charge rows ─────────────────────────────── -->
                <Frame BackgroundColor="White" CornerRadius="12"
                       Padding="0" HasShadow="True">
                    <VerticalStackLayout
                        BindableLayout.ItemsSource="{Binding ExtraCharges}"
                        Spacing="0">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:ExtraChargeEntry">
                                <Grid ColumnDefinitions="*,170"
                                      Padding="16,0"
                                      MinimumHeightRequest="52">
                                    <Grid.Triggers>
                                        <DataTrigger TargetType="Grid"
                                                     Binding="{Binding Amount}"
                                                     Value="0">
                                        </DataTrigger>
                                    </Grid.Triggers>
                                    <Label Grid.Column="0"
                                           Text="{Binding Name, StringFormat='{0}:'}"
                                           FontSize="14"
                                           TextColor="{StaticResource TextPrimary}"
                                           VerticalOptions="Center" />
                                    <Border Grid.Column="1"
                                            BackgroundColor="White"
                                            Stroke="#CCCCCC"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 8"
                                            Padding="10,0"
                                            Margin="0,6">
                                        <Entry Text="{Binding Amount, Mode=TwoWay}"
                                               Keyboard="Numeric"
                                               Placeholder="0"
                                               FontSize="14"
                                               TextColor="{StaticResource TextPrimary}"
                                               PlaceholderColor="{StaticResource TextSecondary}"
                                               BackgroundColor="White"
                                               HeightRequest="40" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </Frame>

                <!-- ── Tax ────────────────────────────────────────────────── -->
                <Frame BackgroundColor="White" CornerRadius="12" Padding="16" HasShadow="True">
                    <Grid ColumnDefinitions="*,170">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                            <Label Text="Tax / GST (%)"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label Text="Applied to sub-total + extras"
                                   FontSize="11"
                                   TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1"
                                BackgroundColor="White"
                                Stroke="#CCCCCC"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 8"
                                Padding="10,0"
                                Margin="0,4">
                            <Entry Text="{Binding TaxPercent, Mode=TwoWay}"
                                   Keyboard="Numeric"
                                   Placeholder="0"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"
                                   PlaceholderColor="{StaticResource TextSecondary}"
                                   BackgroundColor="White"
                                   HorizontalTextAlignment="End"
                                   HeightRequest="44" />
                        </Border>
                    </Grid>
                </Frame>

                <!-- ── Notes ──────────────────────────────────────────────── -->
                <Frame BackgroundColor="White" CornerRadius="12" Padding="16" HasShadow="True">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Notes (optional)"
                               FontSize="14" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                        <Border BackgroundColor="White"
                                Stroke="#CCCCCC" StrokeThickness="1"
                                StrokeShape="RoundRectangle 8"
                                Padding="10,4">
                            <Editor Text="{Binding Notes, Mode=TwoWay}"
                                    Placeholder="Any notes for this invoice..."
                                    HeightRequest="80"
                                    FontSize="13"
                                    TextColor="{StaticResource TextPrimary}"
                                    PlaceholderColor="{StaticResource TextSecondary}"
                                    BackgroundColor="White" />
                        </Border>
                    </VerticalStackLayout>
                </Frame>

                <!-- ── Summary ────────────────────────────────────────────── -->
                <Frame BackgroundColor="White" CornerRadius="12" Padding="16"
                       HasShadow="True" BorderColor="{StaticResource PrimaryColor}">
                    <VerticalStackLayout Spacing="10">

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Sub Total" FontSize="13"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label Grid.Column="1" x:Name="SubTotalLbl"
                                   FontSize="13" TextColor="{StaticResource TextPrimary}" />
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Extra Charges" FontSize="13"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label Grid.Column="1" x:Name="ExtraTotalLbl"
                                   FontSize="13" TextColor="{StaticResource TextPrimary}" />
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label x:Name="TaxLbl" FontSize="13"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label Grid.Column="1" x:Name="TaxAmtLbl"
                                   FontSize="13" TextColor="{StaticResource TextPrimary}" />
                        </Grid>

                        <BoxView HeightRequest="1.5"
                                 BackgroundColor="{StaticResource PrimaryColor}" />

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Grand Total"
                                   FontAttributes="Bold" FontSize="17"
                                   TextColor="{StaticResource PrimaryColor}" />
                            <Label Grid.Column="1" x:Name="GrandTotalLbl"
                                   FontAttributes="Bold" FontSize="17"
                                   TextColor="{StaticResource PrimaryColor}" />
                        </Grid>

                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom buttons -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="10"
              Padding="16,10,16,18" BackgroundColor="{StaticResource BackgroundColor}">
            <Button Grid.Column="0"
                    Text="← Back"
                    Style="{StaticResource OutlineButton}"
                    Clicked="OnBackClicked" />
            <Button Grid.Column="1"
                    Text="Generate Bill →"
                    Style="{StaticResource PrimaryButton}"
                    Clicked="OnGenerateBillClicked" />
        </Grid>

        <!-- Loading overlay -->
        <Grid Grid.RowSpan="2" BackgroundColor="#CC000000"
              x:Name="LoadingOverlay" IsVisible="False">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="12">
                <ActivityIndicator IsRunning="True" Color="White" HeightRequest="50" />
                <Label Text="Creating bill..." TextColor="White"
                       FontSize="16" FontAttributes="Bold" />
            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>
