<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GlassBilling.Views.CustomersPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:GlassBilling.ViewModels"
    xmlns:models="clr-namespace:GlassBilling.Models"
    Title="Customers">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Search bar -->
        <SearchBar
            Grid.Row="0"
            Placeholder="Search customers..."
            Text="{Binding SearchText}"
            Margin="12,8" />

        <!-- Add button -->
        <Button
            Grid.Row="1"
            Text="+ Add Customer"
            Style="{StaticResource PrimaryButton}"
            Command="{Binding NewCustomerCommand}"
            Margin="12,0,12,8" />

        <!-- List -->
        <CollectionView
            Grid.Row="2"
            ItemsSource="{Binding Customers}"
            Margin="12,0">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Customer">
                    <Frame Style="{StaticResource CardFrame}">
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="15" TextColor="#212121" />
                                <Label Text="{Binding Location}" FontSize="13" TextColor="#757575" />
                                <Label Text="{Binding Phone}" FontSize="12" TextColor="#9E9E9E" />
                            </VerticalStackLayout>
                            <Button
                                Grid.Column="1"
                                Text="Edit"
                                Style="{StaticResource OutlineButton}"
                                HeightRequest="36"
                                Padding="12,0"
                                CommandParameter="{Binding .}"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CustomersViewModel}}, Path=EditCustomerCommand}" />
                            <Button
                                Grid.Column="2"
                                Text="🗑"
                                BackgroundColor="Transparent"
                                TextColor="#E53935"
                                FontSize="18"
                                HeightRequest="36"
                                WidthRequest="44"
                                CommandParameter="{Binding .}"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CustomersViewModel}}, Path=DeleteCustomerCommand}" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Margin="0,60">
                    <Label Text="No customers yet" FontSize="16" TextColor="#9E9E9E" HorizontalOptions="Center" />
                    <Label Text='Tap "+ Add Customer" to get started' FontSize="13" TextColor="#BDBDBD" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

        <!-- Edit overlay -->
        <Grid
            Grid.RowSpan="3"
            BackgroundColor="#80000000"
            IsVisible="{Binding IsEditing}">
            <Frame
                BackgroundColor="White"
                CornerRadius="16"
                Padding="20"
                Margin="20"
                VerticalOptions="Center">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Customer Details" Style="{StaticResource SectionHeader}" Margin="0,0,0,8" />

                    <Label Text="Name *" Style="{StaticResource FormLabel}" />
                    <Entry Text="{Binding Name}" Placeholder="Full name" Style="{StaticResource FormEntry}" />

                    <Label Text="Location / Area" Style="{StaticResource FormLabel}" />
                    <Entry Text="{Binding Location}" Placeholder="e.g. Kongad" Style="{StaticResource FormEntry}" />

                    <Label Text="Phone" Style="{StaticResource FormLabel}" />
                    <Entry Text="{Binding Phone}" Placeholder="+91 XXXXX XXXXX" Keyboard="Telephone" Style="{StaticResource FormEntry}" />

                    <Label Text="Address" Style="{StaticResource FormLabel}" />
                    <Editor Text="{Binding Address}" Placeholder="Full address" HeightRequest="80" BackgroundColor="White" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,12,0,0">
                        <Button Grid.Column="0" Text="Cancel" Style="{StaticResource OutlineButton}" Command="{Binding CancelEditCommand}" />
                        <Button Grid.Column="1" Text="Save" Style="{StaticResource PrimaryButton}" Command="{Binding SaveCustomerCommand}" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>
        </Grid>

        <!-- Loading -->
        <ActivityIndicator
            Grid.RowSpan="3"
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            Color="{StaticResource PrimaryColor}"
            HorizontalOptions="Center"
            VerticalOptions="Center" />

    </Grid>
</ContentPage>
