<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Brand purple palette (matching screenshots) -->
    <Color x:Key="PrimaryColor">#5B4FCF</Color>
    <Color x:Key="PrimaryDarkColor">#4A3DB8</Color>
    <Color x:Key="PrimaryLightColor">#7B6FDF</Color>
    <Color x:Key="AccentColor">#2196F3</Color>
    <Color x:Key="SecondaryColor">#EDE9FF</Color>
    <Color x:Key="DangerColor">#E53935</Color>
    <Color x:Key="SuccessColor">#43A047</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="BackgroundColor">#F5F3FF</Color>
    <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
    <Color x:Key="TextPrimary">#212121</Color>
    <Color x:Key="TextSecondary">#757575</Color>
    <Color x:Key="BorderColor">#E0E0E0</Color>

    <!-- Gradient for backgrounds -->
    <Color x:Key="GradientStart">#6A1FCA</Color>
    <Color x:Key="GradientEnd">#3B47D4</Color>

</ResourceDictionary>
